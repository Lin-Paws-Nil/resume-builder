# ============================================
# RAZORPAY CONFIGURATION
# ============================================

# Get these from: https://dashboard.razorpay.com/app/keys
# Make sure you're in TEST MODE when getting test keys

# Server-side keys (NEVER expose to client)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here

# Client-side publishable key (safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Webhook secret (generate random string)
# Generate with: openssl rand -hex 32
# Add this same secret in Razorpay Dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# APP CONFIGURATION
# ============================================

# Your application URL
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# SUPABASE (Database & Auth)
# ============================================

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================
# LINKEDIN OAUTH (Optional)
# ============================================

LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# ============================================
# OPENAI (AI Features)
# ============================================

OPENAI_API_KEY=your_openai_api_key

# ============================================
# NOTES
# ============================================

# 1. Get Razorpay keys from: https://dashboard.razorpay.com/app/keys
# 2. Start with TEST MODE (keys start with rzp_test_)
# 3. For production, switch to LIVE MODE (keys start with rzp_live_)
# 4. Never commit this file to git! It's in .gitignore
# 5. For Vercel deployment, add these in: Settings → Environment Variables
